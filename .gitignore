## Don't Save Secrets That pertain to Secure details
.secrets.yml
vault.yml
## Don't Save Log Files
*.log
support-bundle.zip
.claude
# Don't Include Vagrant support files
.vagrant
id_rsa
Hosts.yml
results.yml

# The core_provisioner driver is fetched at build/bootstrap from the release
# pinned in driver.version — never committed.
driver/

# Shared certificate material is SEEDED from the driver (non-clobbering);
# ssls/ itself is the user's BYO drop zone and stays out of git.
ssls/ca/ca-certificate.crt
ssls/ca/ca-certificate.key
ssls/ca/ca-certificate.no.key
ssls/ca/default-signed.ca
ssls/combined/default-signed.crt
ssls/crt/default-signed.crt
ssls/key/default-signed.key
templates/auto-SHI-Hosts.yml
DeployKey_rsa
*.vdi
vault-Docova.yml

*.IDS
*.ID
*.id
*.ids
SAFE.IDS

# Build Files to Ignore
.DS_Store
*.swp
.classpath
.project
.vscode/
.settings/
.gradle/
build/
test_files/

